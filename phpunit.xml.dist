<?xml version="1.0"?>
<phpunit bootstrap="vendor/autoload.php" colors="true" cacheDirectory=".phpunit.cache">
  <testsuites>
    <testsuite name="Main">
      <directory>tests/</directory>
    </testsuite>
  </testsuites>
  <source>
    <include>
      <directory suffix=".php">src/</directory>
      <directory suffix=".php">tools/</directory>
    </include>
    <exclude>
      <directory suffix=".php">src/ByCity/</directory>
    </exclude>
  </source>
</phpunit>
